# =============================================================================
# CashFlow — Environment Variables
# Copy this file to .env in the appropriate directory and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend  (backend/.env)
# ---------------------------------------------------------------------------

# Stacks network target (devnet | testnet | mainnet)
STACKS_NETWORK=testnet

# Deployer / contract-owner wallet address
WALLET_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Deployer private key — required for on-chain writes (NEVER commit this)
PRIVATE_KEY=

# AI yield agent — set one or more (priority: Groq > xAI Grok > OpenAI)
# Optional: falls back to deterministic allocation when none are set
GROQ_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# x402 micropayment facilitator URL
X402_FACILITATOR_URL=https://x402.aibtc.dev

# Address that receives x402 payments
PAYMENT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# Express server port
PORT=4000

# ---------------------------------------------------------------------------
# Frontend  (frontend/.env)
# ---------------------------------------------------------------------------

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:4000/api
